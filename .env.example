# ---------------------------------------------------------------------------
# Aegis configuration. Copy to `.env` and adjust. All vars are AEGIS_ prefixed.
# The app runs with ZERO setup using these defaults (SQLite + in-memory cache).
# ---------------------------------------------------------------------------

AEGIS_ENVIRONMENT=local
AEGIS_DEBUG=true
AEGIS_LOG_LEVEL=INFO
AEGIS_LOG_JSON=false

# Security — generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AEGIS_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
AEGIS_ACCESS_TOKEN_TTL_SECONDS=900
AEGIS_REFRESH_TOKEN_TTL_SECONDS=1209600

# Persistence. For Postgres use:
#   postgresql+asyncpg://aegis:aegis@localhost:5432/aegis
AEGIS_DATABASE_URL=sqlite+aiosqlite:///./aegis.db
AEGIS_DB_ECHO=false

# Cache / queue. Leave empty to use the in-process fake (great for local dev).
#   redis://localhost:6379/0
AEGIS_REDIS_URL=

# Self-healing engine. Without a key the engine falls back to heuristic-only mode.
AEGIS_ANTHROPIC_API_KEY=
AEGIS_HEALING_MODEL=claude-opus-4-8
AEGIS_HEALING_ENABLED=true
AEGIS_HEALING_MIN_CONFIDENCE=0.6
AEGIS_HEALING_MAX_ATTEMPTS=3

# Worker
AEGIS_WORKER_CONCURRENCY=8
AEGIS_RUN_MAX_RETRIES=2

# Observability
AEGIS_METRICS_ENABLED=true
AEGIS_TRACING_ENABLED=false
AEGIS_OTLP_ENDPOINT=http://localhost:4317

# CORS (comma-separated, JSON list also accepted)
AEGIS_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Rate limiting (per client, sliding window)
AEGIS_RATE_LIMIT_ENABLED=true
AEGIS_RATE_LIMIT_REQUESTS=120
AEGIS_RATE_LIMIT_WINDOW_SECONDS=60
